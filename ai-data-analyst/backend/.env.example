# ============================================================================
# Neural Analyst — Environment Configuration
# ============================================================================
# Copy this file to .env and customize as needed.
# For local development, ONLY the LLM settings below are required.
# Everything else has sensible defaults that work out of the box.
#
# Quick start:
#   1. cp .env.example .env
#   2. Set your LLM_MODEL and API key
#   3. Run: python -m uvicorn app.main:app --reload
# ============================================================================

# ── TIER 1: LLM Provider (required for AI features) ──────────────────────────
# Choose your LLM model. LiteLLM supports 100+ providers:
#   OpenAI:    gpt-4o, gpt-4o-mini, o1, o1-mini
#   Anthropic: claude-sonnet-4-20250514, claude-3-haiku-20240307
#   Google:    gemini/gemini-pro, gemini/gemini-1.5-flash
#   Ollama:    ollama/llama3, ollama/mistral, ollama/codellama (FREE, local!)
#   Mistral:   mistral/mistral-large-latest
#   And more:  https://docs.litellm.ai/docs/providers
LLM_MODEL=gpt-4o-mini

# Set the API key for your chosen provider (uncomment the relevant one):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# MISTRAL_API_KEY=...
# Note: Ollama models need NO API key — just run `ollama serve` locally.

# ── TIER 2: App Behavior (optional) ──────────────────────────────────────────
# Deployment: "self_host" = unlimited OSS (default), "saas" = freemium + subscriptions
# DEPLOYMENT_MODE=self_host

# Authentication: "local" = no login required (default), "jwt" = full auth
AUTH_MODE=local

# Database: defaults to SQLite (zero-config, no server needed)
# Uncomment for PostgreSQL:
# DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/neural_analyst

# Background jobs: "local" = in-process (default), "celery" = distributed
# JOB_EXECUTOR=local

# File storage: "local" = filesystem (default), "s3" = S3-compatible
# OBJECT_STORE_BACKEND=local

# Vector store: "none" = disabled (default), "chroma" = embedded, "pinecone" = managed
# VECTOR_STORE=none
# PINECONE_API_KEY=...

# ── TIER 3: Production Scale (for team/cloud deployments) ────────────────────
# IMPORTANT: Change this to a random secret for any non-local deployment!
# SECRET_KEY=your-random-64-char-secret-here

# PostgreSQL connection (when using DB_URL above):
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=neural_analyst

# Redis (needed for celery workers):
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Celery (distributed job queue):
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS (comma-separated origins or JSON array):
# SECURITY_CORS_ORIGINS=["http://localhost:3000","http://localhost:3002","https://yourdomain.com"]

# S3 storage (when OBJECT_STORE_BACKEND=s3):
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...

# Narrator mode: "deterministic" = no LLM (default), "llm" = AI-powered
# NARRATOR_MODE=deterministic

# ── SaaS Billing (Stripe — only when DEPLOYMENT_MODE=saas) ───────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# FRONTEND_URL=http://localhost:3000
